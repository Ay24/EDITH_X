# EDITH-X Configuration
# Copy this to .env and fill in your values

# ─── App ────────────────────────────────
EDITH_ENV=development
EDITH_SECRET_KEY=change-me-to-a-random-32-char-string
EDITH_HOST=0.0.0.0
EDITH_PORT=8000
EDITH_LOG_LEVEL=INFO

# ─── LLM Providers ──────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...
NVIDIA_API_KEY=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

# ─── Local Models (LM Studio) ────────────
LOCAL_LLM_HOST=http://192.168.56.1:1234/v1
LOCAL_DEFAULT_MODEL=llama-3.2-3b-instruct

# ─── Vector DB ───────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Database ────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edith_x
POSTGRES_USER=edith
POSTGRES_PASSWORD=change-me

# ─── Redis ───────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Memory ──────────────────────────────
MEM0_API_KEY=
# Leave blank to use local Qdrant+Postgres for memory

# ─── Semantic Cache ───────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Model Routing ───────────────────────
# Comma-separated ordered preference
LOCAL_MODELS=llama-3.2-3b-instruct
CLOUD_MODELS=nvidia/llama-3.1-70b-instruct,gpt-4o-mini,gpt-4o,claude-3-5-haiku-20241022,claude-sonnet-4-5

# ─── Cost Thresholds ─────────────────────
MAX_COST_PER_REQUEST_USD=0.10
ESCALATION_CONFIDENCE_THRESHOLD=0.75

# ─── Demo ────────────────────────────────
DEMO_MODE=true
STREAMLIT_PORT=8501
